{
  "name": "cypress-e2e-framework-final-fixed",
  "version": "1.0.0",
  "description": "Simplified Cypress TypeScript E2E framework using Page Object Model for SauceDemo.",
  "private": true,
  "scripts": {
    "open": "cypress run --headed --browser chrome",
    "open:app": "cypress open --browser chrome",
    "test": "cypress run",
    "test:headed": "cypress run --headed",
    "test:chrome": "cypress run --browser chrome",
    "test:edge": "cypress run --browser edge",
    "test:smoke": "cypress run --spec cypress/e2e/saucedemo.cy.ts",
    "test:regression": "cypress run --spec cypress/e2e/saucedemo.cy.ts",
    "report:open": "start \"\" \"cypress/reports/html/index.html\"",
    "clean": "node scripts/clean.js"
  },
  "devDependencies": {
    "@types/node": "20.17.10",
    "cypress": "13.17.0",
    "cypress-mochawesome-reporter": "^3.8.4",
    "typescript": "5.6.3"
  }
}
